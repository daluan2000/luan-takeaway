# 运行模式：
# microservice | monolith
API_MODE=monolith

# OAuth2 客户端凭证：clientId:clientSecret（必须）
# 使用 test:test 以便后端忽略验证码校验（参考 application-dev.yml ignore-clients）
API_CLIENT_CREDENTIAL=test:test

# 请求超时时间（秒）
API_TIMEOUT=10

# ---------------------------------------------------------------------------
# 种子数据生成配置（可选，使用环境变量或命令行参数均可）
# ---------------------------------------------------------------------------
# 种子数据数量
SEED_MERCHANT_COUNT=10
SEED_CUSTOMER_COUNT=50
SEED_DELIVERY_COUNT=10
SEED_DISHES_PER_MERCHANT=20

# 并发种子数（默认值 8）
MAX_SEED_WORKERS=100

# 地址经纬度范围（留空则自动推断全国；若填值则覆盖全国范围）
# 示例（广东省广州市）：
# SEED_LON_MIN=112.7
# SEED_LON_MAX=114.3
# SEED_LAT_MIN=22.8
# SEED_LAT_MAX=23.7
SEED_LON_MIN=
SEED_LON_MAX=
SEED_LAT_MIN=
SEED_LAT_MAX=
