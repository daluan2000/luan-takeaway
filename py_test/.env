# =============================================================================
# pytest 测试配置
# 所有配置项都可通过命令行参数覆盖（命令行 > .env > 默认值）
# =============================================================================

# ---------------------------------------------------------------------------
# 后端 API 配置
# ---------------------------------------------------------------------------
# 运行模式：monolith | microservice
API_MODE=monolith

# OAuth2 客户端凭证：clientId:clientSecret（必须）
# 使用 test:test 以便后端忽略验证码校验（参考 application-dev.yml ignore-clients）
API_CLIENT_CREDENTIAL=test:test

# 请求超时时间（秒）
API_TIMEOUT=10

# 密码加密配置
API_PWD_ENC_KEY=thanks,pig4cloud
API_PWD_ENCRYPT_ENABLED=true

# ---------------------------------------------------------------------------
# 种子数据生成配置
# ---------------------------------------------------------------------------
# 是否强制重建种子数据（true | false）
# 命令行：--fresh-seed
SEED_FRESH=true

# 种子数据数量
SEED_MERCHANT_COUNT=1000
SEED_CUSTOMER_COUNT=500
SEED_DELIVERY_COUNT=100
SEED_DISHES_PER_MERCHANT=10

# 并发种子数
MAX_SEED_WORKERS=100

# ---------------------------------------------------------------------------
# 地址经纬度范围配置（留空则使用北京市市辖区默认值）
# 若填值则覆盖全国范围，用于测试特定区域的商家/客户
# ---------------------------------------------------------------------------
# 示例（广东省广州市）：
# SEED_LON_MIN=112.7
# SEED_LON_MAX=114.3
# SEED_LAT_MIN=22.8
# SEED_LAT_MAX=23.7
SEED_LON_MIN=
SEED_LON_MAX=
SEED_LAT_MIN=
SEED_LAT_MAX=

# ---------------------------------------------------------------------------
# 命令行用法示例
# ---------------------------------------------------------------------------
# pytest                                    # 使用 .env 中的配置
# pytest --fresh-seed                      # 强制重建所有种子数据
# pytest --merchant-count=5                # 只创建 5 个商家
# pytest --customer-count=20               # 只创建 20 个客户
# pytest --dishes-per-merchant=10          # 每个商家只创建 10 道菜
# pytest --lon-min=112 --lon-max=115       # 经纬度范围
# pytest --mode=microservice               # 切换到微服务模式
# pytest --merchant-count=3 --fresh-seed    # 组合使用
